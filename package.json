{
    "name": "obsidian-language-study",
    "version": "0.1.1",
    "description": "阅读、查词、复习、使用、统计全部合一的语言学习 Obsidian 插件",
    "main": "main.js",
    "packageManager": "pnpm@11.5.2",
    "engines": {
        "node": ">=22.18.0"
    },
    "scripts": {
        "dev": "vite build --watch --mode development",
        "typecheck": "vue-tsc --noEmit --skipLibCheck",
        "test": "vitest run",
        "deploy": "npm run build && node scripts/deploy-icloud.mjs",
        "lint": "oxlint --config oxlint.config.mts --tsconfig tsconfig.json .",
        "format": "oxfmt --config oxfmt.config.mts --write --no-error-on-unmatched-pattern \"src/**/*.{ts,vue,css}\" \"tests/**/*.ts\" \"*.{ts,mjs,mts,json,jsonc}\"",
        "format:check": "oxfmt --config oxfmt.config.mts --check --no-error-on-unmatched-pattern \"src/**/*.{ts,vue,css}\" \"tests/**/*.ts\" \"*.{ts,mjs,mts,json,jsonc}\"",
        "check": "pnpm typecheck && pnpm test && pnpm lint && pnpm format:check",
        "build": "pnpm typecheck && pnpm test && vite build --mode production",
        "pub": "node publish.mjs",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [],
    "author": "Shawn",
    "license": "MIT",
    "dependencies": {
        "@vueuse/core": "^14.3.0",
        "ac-auto": "^2.0.0",
        "dexie": "^4.4.3",
        "dexie-export-import": "^4.4.0",
        "downloadjs": "^1.4.7",
        "echarts": "^6.1.0",
        "monkey-around": "^3.0.0",
        "nlcst-to-string": "^4.0.0",
        "parse-english": "^7.0.0",
        "retext-english": "^5.0.0",
        "unified": "^11.0.5",
        "unist-util-modify-children": "^4.0.0",
        "unist-util-visit": "^5.1.0",
        "vue": "^3.5.38"
    },
    "devDependencies": {
        "@types/downloadjs": "^1.4.6",
        "@types/nlcst": "^2.0.3",
        "@types/node": "^25.9.3",
        "@vitejs/plugin-vue": "^6.0.7",
        "happy-dom": "^20.10.2",
        "hash-sum": "^2.0.0",
        "naive-ui": "^2.44.1",
        "obsidian": "1.13.1",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "sass": "^1.101.0",
        "tslib": "2.8.1",
        "typescript": "6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.4"
    }
}
